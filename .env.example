# TheCocktailDB
COCKTAILDB_API_KEY=1
# Сервер
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
# БД
DATABASE_URL=sqlite+aiosqlite:///./cocktails.db
DATABASE_URL_SYNC=sqlite:///./cocktails.db
# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# JWT
JWT_SECRET=your_jwt_secret_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
# Session middleware
SESSION_SECRET=your_session_secret_hex_32
# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
